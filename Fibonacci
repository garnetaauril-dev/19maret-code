#include <stdio.h>

int main() {
    int n, a = 0, b = 1, next;
    printf("Tampilkan Fibonacci sampai: ");
    scanf("%d", &n);

    printf("%d %d ", a, b);
    next = a + b;

    while (next <= n) {
        printf("%d ", next);
        a = b;
        b = next;
        next = a + b;
    }

    return 0;
}
